{
  "name": "voby-query",
  "version": "0.7.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "dev": "vp pack --watch",
    "playground:build": "pnpm --filter voby-query-playground build",
    "playground:dev": "pnpm --filter voby-query-playground dev",
    "format": "vp fmt . --write",
    "prepublish": "vp check && vp pack",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "prepare": "vp config"
  },
  "dependencies": {
    "std-env": "^4.1.0",
    "voby": "^0.58.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@typescript/native-preview": "npm:typescript@7.0.1-rc",
    "@vitest/browser-playwright": "^4.1.9",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "typescript": "7.0.1-rc",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.22",
    "vite-plus": "^0.2.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
