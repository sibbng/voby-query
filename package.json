{
  "name": "voby-query",
  "version": "0.7.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "dev": "vp pack --watch",
    "playground:build": "pnpm --filter voby-query-playground build",
    "playground:dev": "pnpm --filter voby-query-playground dev",
    "format": "vp fmt . --write",
    "prepublish": "vp check && vp pack",
    "test": "vp test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "std-env": "^3.9.0",
    "voby": "^0.58.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "playwright": "^1.60.0",
    "typescript": "7.0.1-rc",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.22",
    "vite-plus": "^0.1.22"
  },
  "packageManager": "pnpm@10.6.3"
}
